      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "${POSTGRES_URL}"],
      "requiredSecrets": [
        {
          "key": "POSTGRES_URL",
          "label": "PostgreSQL connection URL",
          "target": "env",
          "required": true,
          "help": "postgresql://user:pass@host:5432/db"
        }
      ],
      "tags": ["data", "database"],
      "source": "bundled",
      "homepage": "https://github.com/modelcontextprotocol/servers"
    },
    {
