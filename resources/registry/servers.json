{
  "version": 1,
  "updated": "2026-06-11",
  "servers": [
    {
      "id": "filesystem",
      "name": "Filesystem",
      "description": "Read/write access to a sandboxed set of local directories.",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "${ROOT_DIR}"],
      "tags": ["files", "official", "core"],
      "source": "bundled",
      "homepage": "https://github.com/modelcontextprotocol/servers"
    },
    {
      "id": "git",
      "name": "Git",
      "description": "Inspect and operate on local Git repositories.",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-git"],
      "tags": ["dev", "git", "official"],
      "source": "bundled",
      "homepage": "https://github.com/modelcontextprotocol/servers"
    },
    {
      "id": "github",
      "name": "GitHub",
      "description": "Manage repos, issues, and PRs through the GitHub API.",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {},
      "requiredSecrets": [
        {
          "key": "GITHUB_PERSONAL_ACCESS_TOKEN",
          "label": "GitHub Personal Access Token",
          "target": "env",
          "required": true,
          "help": "Create at github.com/settings/tokens"
        }
      ],
      "tags": ["dev", "git", "official"],
      "source": "bundled",
      "homepage": "https://github.com/modelcontextprotocol/servers"
    },
    {
      "id": "memory",
      "name": "Memory",
