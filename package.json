{
  "name": "mcp-command-center",
  "version": "0.1.0",
  "description": "A graphical, AI-assisted control plane for connecting AI clients to MCP servers across your system.",
  "author": "OpenClaw Community",
  "license": "MIT",
  "main": "./out/main/index.js",
  "homepage": "https://github.com/sasha-thecornerspore-dev/mcp-command-center",
  "repository": {
    "type": "git",
    "url": "https://github.com/sasha-thecornerspore-dev/mcp-command-center.git"
  },
  "bugs": {
    "url": "https://github.com/sasha-thecornerspore-dev/mcp-command-center/issues"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^39.8.5",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2",
    "vite": "^6.4.2",
    "vitest": "^4.1.8"
  }
}
